{
    "annotations": {
        "list": []
    },
    "description": "SoulWallet API performance metrics - request rates, latency, and errors",
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "liveNow": false,
    "panels": [
        {
            "title": "Request Rate",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "unit": "reqps"
                }
            },
            "targets": [
                {
                    "expr": "sum(rate(soulwallet_http_request_duration_seconds_count[5m]))",
                    "legendFormat": "Total Requests/s",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Error Rate",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "fixedColor": "red",
                        "mode": "fixed"
                    },
                    "unit": "percentunit"
                }
            },
            "targets": [
                {
                    "expr": "sum(rate(soulwallet_http_request_duration_seconds_count{status_code=~\"5..\"}[5m])) / sum(rate(soulwallet_http_request_duration_seconds_count[5m]))",
                    "legendFormat": "5xx Error Rate",
                    "refId": "A"
                },
                {
                    "expr": "sum(rate(soulwallet_http_request_duration_seconds_count{status_code=~\"4..\"}[5m])) / sum(rate(soulwallet_http_request_duration_seconds_count[5m]))",
                    "legendFormat": "4xx Error Rate",
                    "refId": "B"
                }
            ]
        },
        {
            "title": "P95 Latency",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 8
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "unit": "s"
                }
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.95, sum(rate(soulwallet_http_request_duration_seconds_bucket[5m])) by (le))",
                    "legendFormat": "P95 Latency",
                    "refId": "A"
                },
                {
                    "expr": "histogram_quantile(0.50, sum(rate(soulwallet_http_request_duration_seconds_bucket[5m])) by (le))",
                    "legendFormat": "P50 Latency",
                    "refId": "B"
                }
            ]
        },
        {
            "title": "Top Endpoints by Traffic",
            "type": "bargauge",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps"
                }
            },
            "targets": [
                {
                    "expr": "topk(10, sum by (route) (rate(soulwallet_http_request_duration_seconds_count[5m])))",
                    "legendFormat": "{{route}}",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "API Status",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 0,
                "y": 16
            },
            "fieldConfig": {
                "defaults": {
                    "mappings": [
                        {
                            "type": "value",
                            "options": {
                                "1": {
                                    "text": "UP",
                                    "color": "green"
                                }
                            }
                        },
                        {
                            "type": "value",
                            "options": {
                                "0": {
                                    "text": "DOWN",
                                    "color": "red"
                                }
                            }
                        }
                    ]
                }
            },
            "targets": [
                {
                    "expr": "soulwallet_up",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Active Requests",
            "type": "gauge",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 6,
                "y": 16
            },
            "fieldConfig": {
                "defaults": {
                    "max": 1000,
                    "thresholds": {
                        "steps": [
                            {
                                "value": 0,
                                "color": "green"
                            },
                            {
                                "value": 500,
                                "color": "yellow"
                            },
                            {
                                "value": 800,
                                "color": "red"
                            }
                        ]
                    }
                }
            },
            "targets": [
                {
                    "expr": "sum(rate(soulwallet_http_request_duration_seconds_count[1m])) * 60",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Success Rate",
            "type": "gauge",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 12,
                "y": 16
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "percentunit",
                    "min": 0,
                    "max": 1,
                    "thresholds": {
                        "steps": [
                            {
                                "value": 0,
                                "color": "red"
                            },
                            {
                                "value": 0.9,
                                "color": "yellow"
                            },
                            {
                                "value": 0.99,
                                "color": "green"
                            }
                        ]
                    }
                }
            },
            "targets": [
                {
                    "expr": "sum(rate(soulwallet_http_request_duration_seconds_count{status_code=~\"2..\"}[5m])) / sum(rate(soulwallet_http_request_duration_seconds_count[5m]))",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Avg Response Time",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 18,
                "y": 16
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "ms"
                }
            },
            "targets": [
                {
                    "expr": "sum(rate(soulwallet_http_request_duration_seconds_sum[5m])) / sum(rate(soulwallet_http_request_duration_seconds_count[5m])) * 1000",
                    "refId": "A"
                }
            ]
        }
    ],
    "refresh": "10s",
    "schemaVersion": 38,
    "style": "dark",
    "tags": [
        "soulwallet",
        "api",
        "performance"
    ],
    "templating": {
        "list": []
    },
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "timepicker": {},
    "timezone": "browser",
    "title": "API Performance",
    "uid": "soulwallet-api-performance",
    "version": 1
}