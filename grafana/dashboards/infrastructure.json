{
    "annotations": {
        "list": []
    },
    "description": "Infrastructure health metrics - database, cache, memory, and CPU",
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "panels": [
        {
            "title": "Database Connection Pool",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short"
                }
            },
            "targets": [
                {
                    "expr": "soulwallet_prisma_pool_active_connections",
                    "legendFormat": "Active",
                    "refId": "A"
                },
                {
                    "expr": "soulwallet_prisma_pool_idle_connections",
                    "legendFormat": "Idle",
                    "refId": "B"
                },
                {
                    "expr": "soulwallet_prisma_pool_total_connections",
                    "legendFormat": "Total",
                    "refId": "C"
                }
            ]
        },
        {
            "title": "Database Pool Utilization",
            "type": "gauge",
            "gridPos": {
                "h": 8,
                "w": 6,
                "x": 12,
                "y": 0
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "max": 100,
                    "thresholds": {
                        "steps": [
                            {
                                "value": 0,
                                "color": "green"
                            },
                            {
                                "value": 70,
                                "color": "yellow"
                            },
                            {
                                "value": 90,
                                "color": "red"
                            }
                        ]
                    }
                }
            },
            "targets": [
                {
                    "expr": "soulwallet_prisma_pool_utilization_percent",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Database Pool Health",
            "type": "stat",
            "gridPos": {
                "h": 8,
                "w": 6,
                "x": 18,
                "y": 0
            },
            "fieldConfig": {
                "defaults": {
                    "mappings": [
                        {
                            "type": "value",
                            "options": {
                                "1": {
                                    "text": "HEALTHY",
                                    "color": "green"
                                }
                            }
                        },
                        {
                            "type": "value",
                            "options": {
                                "0": {
                                    "text": "UNHEALTHY",
                                    "color": "red"
                                }
                            }
                        }
                    ]
                }
            },
            "targets": [
                {
                    "expr": "soulwallet_prisma_pool_healthy",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Redis Cache Hit Rate",
            "type": "gauge",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 0,
                "y": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "percentunit",
                    "min": 0,
                    "max": 1,
                    "thresholds": {
                        "steps": [
                            {
                                "value": 0,
                                "color": "red"
                            },
                            {
                                "value": 0.5,
                                "color": "yellow"
                            },
                            {
                                "value": 0.8,
                                "color": "green"
                            }
                        ]
                    }
                }
            },
            "targets": [
                {
                    "expr": "soulwallet_redis_cache_hit_rate",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Redis Cache Latency",
            "type": "stat",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 8,
                "y": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "ms",
                    "thresholds": {
                        "steps": [
                            {
                                "value": 0,
                                "color": "green"
                            },
                            {
                                "value": 20,
                                "color": "yellow"
                            },
                            {
                                "value": 50,
                                "color": "red"
                            }
                        ]
                    }
                }
            },
            "targets": [
                {
                    "expr": "soulwallet_redis_cache_avg_latency_ms",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Redis Operations",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 16,
                "y": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short"
                }
            },
            "targets": [
                {
                    "expr": "soulwallet_redis_cache_hits_total",
                    "legendFormat": "Hits",
                    "refId": "A"
                },
                {
                    "expr": "soulwallet_redis_cache_misses_total",
                    "legendFormat": "Misses",
                    "refId": "B"
                },
                {
                    "expr": "soulwallet_redis_cache_errors_total",
                    "legendFormat": "Errors",
                    "refId": "C"
                }
            ]
        },
        {
            "title": "Memory Usage",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 16
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "bytes"
                }
            },
            "targets": [
                {
                    "expr": "process_resident_memory_bytes",
                    "legendFormat": "RSS",
                    "refId": "A"
                },
                {
                    "expr": "process_heap_bytes",
                    "legendFormat": "Heap",
                    "refId": "B"
                }
            ]
        },
        {
            "title": "CPU Usage",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 16
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "percentunit"
                }
            },
            "targets": [
                {
                    "expr": "rate(process_cpu_seconds_total[5m])",
                    "legendFormat": "CPU",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Event Loop Lag",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 24
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "s"
                }
            },
            "targets": [
                {
                    "expr": "nodejs_eventloop_lag_seconds",
                    "legendFormat": "Lag",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Active Handles",
            "type": "stat",
            "gridPos": {
                "h": 8,
                "w": 6,
                "x": 12,
                "y": 24
            },
            "targets": [
                {
                    "expr": "nodejs_active_handles_total",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "Active Requests",
            "type": "stat",
            "gridPos": {
                "h": 8,
                "w": 6,
                "x": 18,
                "y": 24
            },
            "targets": [
                {
                    "expr": "nodejs_active_requests_total",
                    "refId": "A"
                }
            ]
        }
    ],
    "refresh": "10s",
    "schemaVersion": 38,
    "style": "dark",
    "tags": [
        "soulwallet",
        "infrastructure"
    ],
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "title": "Infrastructure Health",
    "uid": "soulwallet-infrastructure",
    "version": 1
}