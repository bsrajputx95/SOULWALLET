{
  "cli": {
    "version": ">= 3.14.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "channel": "development",
      "developmentClient": false,
      "distribution": "internal",
      "node": "22.11.0",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://soulwallet-production-48bf.up.railway.app",
        "EXPO_PUBLIC_SOLANA_RPC_URL": "https://api.mainnet-beta.solana.com",
        "EXPO_PUBLIC_DEV_MODE": "false",
        "EXPO_PUBLIC_LOG_LEVEL": "warn"
      }
    },
    "beta-apk": {
      "channel": "beta",
      "distribution": "internal",
      "node": "22.11.0",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://soulwallet-production-48bf.up.railway.app",
        "EXPO_PUBLIC_SOLANA_RPC_URL": "https://api.mainnet-beta.solana.com",
        "EXPO_PUBLIC_DEV_MODE": "false",
        "EXPO_PUBLIC_LOG_LEVEL": "warn",
        "NODE_OPTIONS": "--max-old-space-size=4096"
      }
    },
    "production": {
      "channel": "production",
      "distribution": "store",
      "autoIncrement": true,
      "credentialsSource": "remote",
      "node": "22.11.0",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://soulwallet-production-48bf.up.railway.app",
        "EXPO_PUBLIC_SOLANA_RPC_URL": "https://api.mainnet-beta.solana.com",
        "EXPO_PUBLIC_DEV_MODE": "false",
        "EXPO_PUBLIC_LOG_LEVEL": "warn"
      }
    }
  }
}