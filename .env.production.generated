# Soul Wallet Production Environment Variables
# Generated: 2025-11-26T00:00:00.000Z
# ⚠️ CRITICAL: Keep this file secure and never commit to version control
# ⚠️ After setting Railway environment variables, DELETE this file or move to secure storage

#############################################
# Core Configuration
#############################################
NODE_ENV=production
PORT=3001
HOST=0.0.0.0
APP_NAME="Soul Wallet"
APP_URL=https://soulwallet.app
API_URL=https://soulwallet-production.up.railway.app

#############################################
# Database Configuration
# UPDATE: Replace with actual Railway PostgreSQL connection string
#############################################
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@YOUR_HOST.railway.app:5432/railway?sslmode=require"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=true

#############################################
# Redis Configuration
# UPDATE: Replace with actual Railway Redis connection string
#############################################
REDIS_URL="redis://default:YOUR_PASSWORD@YOUR_HOST.railway.app:6379"
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000

#############################################
# Security Keys (MUST BE REGENERATED BEFORE DEPLOYMENT!)
# Run: node scripts/generate-production-keys.js to regenerate
# Or generate manually: openssl rand -base64 32
#############################################
# ⚠️ PLACEHOLDER VALUES - REGENERATE BEFORE USE!
# These are NOT real secrets - run the generation script or use:
#   openssl rand -base64 32 (for base64 keys)
#   openssl rand -hex 32 (for hex keys like WALLET_ENCRYPTION_KEY)
JWT_SECRET="<REGENERATE: openssl rand -base64 32>"
JWT_REFRESH_SECRET="<REGENERATE: openssl rand -base64 32>"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_EXP_SECONDS=900

WALLET_ENCRYPTION_KEY="<REGENERATE: openssl rand -hex 32>"
ADMIN_KEY="<REGENERATE: openssl rand -base64 32>"
ADMIN_API_KEY="<REGENERATE: openssl rand -base64 32>"
ENCRYPTION_KEY="<REGENERATE: openssl rand -hex 32>"
SESSION_SECRET="<REGENERATE: openssl rand -base64 32>"
CSRF_SECRET="<REGENERATE: openssl rand -base64 32>"
WEBHOOK_SECRET="<REGENERATE: openssl rand -base64 32>"
API_SECRET_KEY="<REGENERATE: openssl rand -base64 32>"

#############################################
# CSRF Protection (ENABLED for production)
#############################################
CSRF_ENABLED=true

#############################################
# Session Security
#############################################
SESSION_FINGERPRINT_STRICT=true
SESSION_CLEANUP_INTERVAL_HOURS=24
SESSION_TIMEOUT_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=7
MAX_SESSIONS_PER_USER=5

#############################################
# Authentication Settings
#############################################
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
ACCOUNT_LOCKOUT_DURATION_MINUTES=30
OTP_EXPIRES_IN_MINUTES=10
PASSWORD_MIN_LENGTH=8
REQUIRE_EMAIL_VERIFICATION=true
BCRYPT_ROUNDS=12

#############################################
# Rate Limiting
#############################################
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_API_MAX=1000

#############################################
# Email Configuration
# UPDATE: Configure with actual email provider
# Options: smtp, sendgrid, resend, console (dev only)
#############################################
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@soulwallet.app
EMAIL_FROM_NAME=SoulWallet

# SMTP Configuration (if EMAIL_PROVIDER="smtp")
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# SendGrid Configuration (if EMAIL_PROVIDER="sendgrid")
# SENDGRID_API_KEY=SG.your-sendgrid-api-key

# Resend Configuration (if EMAIL_PROVIDER="resend")
# RESEND_API_KEY=re_your-resend-api-key

#############################################
# Blockchain Configuration - Helius RPC
# UPDATE: Replace with your actual Helius API key from https://helius.dev
# Get a free API key at: https://dev.helius.xyz/dashboard/app
#############################################
# ⚠️ PLACEHOLDER VALUES - REPLACE WITH REAL HELIUS CREDENTIALS!
HELIUS_API_KEY="<REPLACE: Get API key from https://dev.helius.xyz/dashboard/app>"
HELIUS_RPC_URL="<REPLACE: https://mainnet.helius-rpc.com/?api-key=YOUR_ACTUAL_KEY>"
HELIUS_WS_URL="<REPLACE: wss://mainnet.helius-rpc.com/?api-key=YOUR_ACTUAL_KEY>"
SOLANA_RPC_URL="<REPLACE: https://mainnet.helius-rpc.com/?api-key=YOUR_ACTUAL_KEY>"
EXPO_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_NETWORK=mainnet-beta
SOLANA_COMMITMENT=confirmed
HEALTH_CHECK_PORT=3002

#############################################
# Monitoring & Analytics
# UPDATE: Configure with actual Sentry DSN from https://sentry.io
#############################################
# ⚠️ PLACEHOLDER VALUES - REPLACE WITH REAL SENTRY CREDENTIALS!
# Get your DSN from: Sentry Dashboard > Settings > Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN="<PLACEHOLDER: https://your-key@sentry.io/your-project-id>"
SENTRY_AUTH_TOKEN="<PLACEHOLDER: your-sentry-auth-token>"
LOG_LEVEL=info
ENABLE_ANALYTICS=true

#############################################
# Feature Flags
#############################################
FEATURE_SEND_ENABLED=true
FEATURE_SWAP_ENABLED=true
FEATURE_COPY_TRADING_ENABLED=true
FEATURE_SOCIAL_ENABLED=true
FEATURE_SIMULATION_MODE=false
FEATURE_TRANSACTION_MONITORING=true
MAINTENANCE_MODE=false

#############################################
# Development Settings (DISABLED for production)
#############################################
ENABLE_PLAYGROUND=false
ENABLE_INTROSPECTION=false

#############################################
# CORS & Security Headers
# UPDATE: Configure with actual production domains
#############################################
ALLOWED_ORIGINS=https://soulwallet-production.up.railway.app,https://soulwallet.app,https://www.soulwallet.app,https://app.soulwallet.com
TRUSTED_PROXIES=true
SECURE_COOKIES=true
SAME_SITE_COOKIES=strict

#############################################
# Security Alerts
#############################################
ENABLE_SUSPICIOUS_LOGIN_ALERTS=true
ENABLE_ACCOUNT_LOCKOUT_NOTIFICATIONS=true
ENABLE_SESSION_ACTIVITY_LOGGING=true
ENABLE_GEOLOCATION_TRACKING=false

#############################################
# Cleanup Service Configuration
#############################################
CLEANUP_EXPIRED_SESSIONS_HOURS=24
CLEANUP_OLD_LOGIN_ATTEMPTS_DAYS=30
CLEANUP_SESSION_ACTIVITIES_DAYS=90
CLEANUP_EXPIRED_OTPS_HOURS=1
AUTO_UNLOCK_EXPIRED_ACCOUNTS=true

#############################################
# Cache Configuration
#############################################
PRICE_CACHE_TTL=60
DASHBOARD_CACHE_TTL=15
MARKET_LIST_TTL=60
TOKEN_DETAIL_TTL=60
RUG_CACHE_TTL=300
CACHE_TTL=3600

#############################################
# Security Configuration
#############################################
MIN_LIQUIDITY_USD=10000
MIN_TOKEN_AGE_HOURS=24
MAX_OWNER_CONCENTRATION=0.5

#############################################
# Admin Configuration
#############################################
ADMIN_EMAILS=admin@soulwallet.app
ADMIN_DASHBOARD_ENABLED=true
ADMIN_2FA_REQUIRED=true

#############################################
# Backup Configuration (Optional)
#############################################
BACKUP_ENABLED=false
# BACKUP_S3_BUCKET=soulwallet-backups
# BACKUP_RETENTION_DAYS=30
# AWS_REGION=us-east-1

#############################################
# Push Notifications (Optional)
#############################################
# EXPO_ACCESS_TOKEN=your-expo-access-token
# FCM_SERVER_KEY=your-fcm-server-key
# APNS_KEY_ID=your-apns-key-id
# APNS_TEAM_ID=your-apns-team-id

#############################################
# Webhooks (Optional)
#############################################
# DISCORD_WEBHOOK_URL=
# SLACK_WEBHOOK_URL=

#############################################
# Performance & Caching
#############################################
CDN_URL=https://cdn.soulwallet.app
ENABLE_COMPRESSION=true
CLUSTER_WORKERS=4
