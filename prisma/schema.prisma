generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto]
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  username             String                @unique
  password             String
  name                 String?
  walletAddress        String?
  walletVerifiedAt     DateTime?
  emailVerifiedAt      DateTime?
  lockedUntil          DateTime?
  failedLoginAttempts  Int                   @default(0)
  role                 Role                  @default(USER)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  emailHash            String?               @unique @db.VarChar(64)
  walletAddressHash    String?               @unique @db.VarChar(64)
  bio                  String?
  profileImage         String?
  coverImage           String?
  isVerified           Boolean               @default(false)
  badge                UserBadge             @default(GENERAL)
  vipPrice             Float?
  vipDescription       String?
  followersCount       Int                   @default(0)
  followingCount       Int                   @default(0)
  vipFollowersCount    Int                   @default(0)
  copyTradersCount     Int                   @default(0)
  roi30d               Float?
  pnl24h               Float?
  pnl1w                Float?
  pnl1m                Float?
  pnl90d               Float?
  maxDrawdown          Float?
  winRate              Float?
  totalTrades          Int                   @default(0)
  statsUpdatedAt       DateTime?
  amlAlerts            AMLAlert[]
  apiKeys              ApiKey[]
  authorizationAudits  AuthorizationAudit[]
  consentLogs          ConsentLog[]
  contacts             Contact[]
  copyTrades           CopyTrading[]
  custodialWallet      CustodialWallet?
  dataDeletionRequests DataDeletionRequest[]
  dataExportRequests   DataExportRequest[]
  deadLetterQueueItems DeadLetterQueueItem[]
  devices              Device[]
  financialAuditLogs   FinancialAuditLog[]
  following            Follow[]              @relation("UserFollowers")
  followers            Follow[]              @relation("UserFollowing")
  ibuyPurchases        IBuyPurchase[]
  ibuySettings         IBuySettings?
  kycVerification      KYCVerification?
  notifications        Notification[]
  otps                 OTP[]
  portfolioSnapshots   PortfolioSnapshot[]
  postComments         PostComment[]
  postLikes            PostLike[]
  postVotes            PostVote[]
  posts                Post[]
  pushTokens           PushToken[]
  reposts              Repost[]
  sessionActivities    SessionActivity[]
  sessions             Session[]
  transactions         Transaction[]
  settings             UserSettings?
  vipSubscribers       VIPSubscription[]     @relation("VIPCreator")
  vipSubscriptions     VIPSubscription[]     @relation("VIPSubscriber")
  wallets              Wallet[]
  webhooks             Webhook[]

  @@index([walletAddress])
  @@index([email, emailVerifiedAt])
  @@index([createdAt])
  @@index([createdAt, isVerified])
  @@index([emailHash])
  @@index([walletAddressHash])
  @@map("users")
}

model Session {
  id                String            @id @default(cuid())
  userId            String
  token             String            @unique
  expiresAt         DateTime
  ipAddress         String?
  userAgent         String?
  lastActivityAt    DateTime          @default(now())
  createdAt         DateTime          @default(now())
  sessionActivities SessionActivity[]
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([userId, lastActivityAt])
  @@map("sessions")
}

model Wallet {
  id                 String              @id @default(cuid())
  userId             String
  publicKey          String              @unique
  privateKey         String
  encryptedMnemonic  String?
  isPrimary          Boolean             @default(false)
  balance            Float               @default(0)
  network            String              @default("mainnet-beta")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  holdings           TokenHolding[]
  walletTransactions WalletTransaction[]
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([publicKey])
  @@index([userId, isPrimary])
  @@map("wallets")
}

model TokenHolding {
  id        String   @id @default(cuid())
  walletId  String
  mint      String
  symbol    String
  name      String
  amount    Float
  decimals  Int
  priceUSD  Float?
  valueUSD  Float?
  logo      String?
  updatedAt DateTime @updatedAt
  wallet    Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, mint])
  @@index([walletId])
  @@map("token_holdings")
}

model WalletTransaction {
  id          String            @id @default(cuid())
  walletId    String
  signature   String            @unique
  type        TransactionType
  status      TransactionStatus
  fromAddress String?
  toAddress   String?
  amount      Float?
  tokenMint   String?
  tokenSymbol String?
  fee         Float?
  blockTime   DateTime?
  createdAt   DateTime          @default(now())
  wallet      Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([signature])
  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

model OTP {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      OTPType
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [email], references: [email])

  @@index([email, type])
  @@index([code])
  @@map("otps")
}

model SignatureNonce {
  id        String   @id @default(cuid())
  nonce     String   @unique
  userId    String
  publicKey String
  createdAt DateTime @default(now())
  expiresAt DateTime
  used      Boolean  @default(false)

  @@index([nonce])
  @@index([userId, createdAt])
  @@map("signature_nonces")
}

model ApiKey {
  id                  String               @id @default(cuid())
  userId              String
  name                String
  keyHash             String               @unique
  keyPrefix           String
  scope               ApiKeyScope          @default(READ_ONLY)
  permissions         Json?
  ipWhitelist         String[]
  isActive            Boolean              @default(true)
  expiresAt           DateTime?
  lastUsedAt          DateTime?
  usageCount          Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  authorizationAudits AuthorizationAudit[]

  @@index([userId, isActive])
  @@index([keyHash])
  @@map("api_keys")
}

model AuthorizationAudit {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String?
  resourceId String?
  endpoint   String
  allowed    Boolean
  reason     String?
  ipAddress  String
  userAgent  String?
  role       Role?
  apiKeyId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  apiKey     ApiKey?  @relation(fields: [apiKeyId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([allowed, createdAt])
  @@index([action, createdAt])
  @@map("authorization_audits")
}

model Device {
  id          String    @id @default(cuid())
  userId      String
  fingerprint String
  ipAddress   String?
  userAgent   String?
  name        String?
  deviceType  String?
  browser     String?
  os          String?
  isTrusted   Boolean   @default(false)
  trustedAt   DateTime?
  lastSeenAt  DateTime  @default(now())
  loginCount  Int       @default(1)
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([userId, lastSeenAt])
  @@index([fingerprint])
  @@map("devices")
}

model Transaction {
  id          String            @id @default(cuid())
  userId      String
  signature   String            @unique
  type        TransactionType
  amount      Float
  token       String
  tokenSymbol String
  from        String
  to          String
  fee         Float
  status      TransactionStatus
  notes       String?
  createdAt   DateTime          @default(now())
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([type, userId])
  @@index([signature])
  @@map("transactions")
}

model Contact {
  id        String   @id @default(cuid())
  userId    String
  name      String
  address   String
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, address])
  @@index([userId])
  @@map("contacts")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model PortfolioSnapshot {
  id            String   @id @default(cuid())
  userId        String
  totalValueUSD Float
  tokens        Json
  timestamp     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
  @@map("portfolio_snapshots")
}

model LoginAttempt {
  id            String   @id @default(cuid())
  identifier    String
  ipAddress     String
  userAgent     String?
  successful    Boolean
  failureReason String?
  createdAt     DateTime @default(now())

  @@index([identifier, createdAt])
  @@index([ipAddress, createdAt])
  @@map("login_attempts")
}

model SessionActivity {
  id         String   @id @default(cuid())
  sessionId  String
  userId     String
  action     String
  ipAddress  String
  userAgent  String?
  metadata   Json?
  suspicious Boolean  @default(false)
  createdAt  DateTime @default(now())
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([suspicious, createdAt])
  @@map("session_activities")
}

model Post {
  id                   String         @id @default(cuid())
  userId               String
  content              String
  visibility           PostVisibility @default(PUBLIC)
  mentionedTokenName   String?
  mentionedTokenSymbol String?
  mentionedTokenMint   String?
  images               Json?
  likesCount           Int            @default(0)
  commentsCount        Int            @default(0)
  repostsCount         Int            @default(0)
  agreeCount           Int            @default(0)
  disagreeCount        Int            @default(0)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  ibuyPurchases        IBuyPurchase[]
  comments             PostComment[]
  likes                PostLike[]
  votes                PostVote[]
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reposts              Repost[]

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@index([visibility])
  @@index([mentionedTokenSymbol])
  @@index([userId, createdAt(sort: Desc)])
  @@index([mentionedTokenSymbol, createdAt(sort: Desc)])
  @@index([visibility, likesCount(sort: Desc)])
  @@index([visibility, createdAt(sort: Desc), likesCount(sort: Desc)])
  @@map("posts")
}

model PostVote {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  vote      Boolean
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@index([userId])
  @@map("post_votes")
}

model IBuySettings {
  id            String   @id @default(cuid())
  userId        String   @unique
  buyAmount     Float    @default(10)
  slippage      Float    @default(0.5)
  inputCurrency String   @default("SOL")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ibuy_settings")
}

model IBuyPurchase {
  id              String    @id @default(cuid())
  userId          String
  postId          String
  tokenMint       String
  tokenSymbol     String?
  tokenName       String?
  amountBought    Float
  amountRemaining Float     @default(0)
  priceInUsdc     Float
  buyTxSig        String    @unique
  sellAmountUsdc  Float?
  sellTxSig       String?
  soldAt          DateTime?
  profitLoss      Float?
  creatorFee      Float?
  creatorFeeTxSig String?
  status          String    @default("OPEN")
  createdAt       DateTime  @default(now())
  post            Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@index([tokenMint])
  @@index([postId])
  @@index([status, createdAt(sort: Desc)])
  @@map("ibuy_purchases")
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@index([userId])
  @@map("post_likes")
}

model PostComment {
  id        String        @id @default(cuid())
  postId    String
  userId    String
  content   String
  parentId  String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  parent    PostComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   PostComment[] @relation("CommentReplies")
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@index([parentId])
  @@map("post_comments")
}

model Repost {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  comment   String?
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("reposts")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model VIPSubscription {
  id                   String   @id @default(cuid())
  subscriberId         String
  creatorId            String
  priceInSol           Float
  expiresAt            DateTime
  autoRenew            Boolean  @default(true)
  transactionSignature String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  creator              User     @relation("VIPCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  subscriber           User     @relation("VIPSubscriber", fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([subscriberId, creatorId])
  @@index([subscriberId])
  @@index([creatorId])
  @@index([expiresAt])
  @@map("vip_subscriptions")
}

model UserSettings {
  id               String   @id @default(cuid())
  userId           String   @unique
  notifications    Json?
  privacy          Json?
  security         Json?
  adminIpWhitelist String[] @default([])
  preferences      Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String
  platform  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId, active])
  @@map("push_tokens")
}

model TraderProfile {
  id             String                      @id @default(cuid())
  walletAddress  String                      @unique
  username       String?
  avatarUrl      String?
  bio            String?
  totalFollowers Int                         @default(0)
  totalTrades    Int                         @default(0)
  winRate        Float                       @default(0)
  totalROI       Float                       @default(0)
  avgTradeSize   Float                       @default(0)
  totalVolume    Float                       @default(0)
  roi7d          Float                       @default(0)
  roi30d         Float                       @default(0)
  roi90d         Float                       @default(0)
  isFeatured     Boolean                     @default(false)
  featuredOrder  Int?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  copiers        CopyTrading[]
  monitored      MonitoredWallet[]
  snapshots      TraderPerformanceSnapshot[]

  @@index([isFeatured, featuredOrder])
  @@index([totalROI])
  @@index([walletAddress])
  @@index([totalROI(sort: Desc), isFeatured])
  @@map("trader_profiles")
}

model TraderPerformanceSnapshot {
  id             String        @id @default(cuid())
  traderId       String
  date           DateTime
  roi            Float
  totalPnL       Float
  totalTrades    Int
  totalFollowers Int
  winRate        Float
  createdAt      DateTime      @default(now())
  trader         TraderProfile @relation(fields: [traderId], references: [id], onDelete: Cascade)

  @@unique([traderId, date])
  @@index([traderId, date])
  @@map("trader_performance_snapshots")
}

model CopyTrading {
  id                  String        @id @default(cuid())
  userId              String
  traderId            String
  isActive            Boolean       @default(true)
  totalBudget         Float
  amountPerTrade      Float
  stopLoss            Float?
  takeProfit          Float?
  maxSlippage         Float         @default(0.5)
  exitWithTrader      Boolean       @default(false)
  totalCopied         Int           @default(0)
  activeTrades        Int           @default(0)
  totalProfit         Float         @default(0)
  totalFeesPaid       Float         @default(0)
  minProfitForSharing Float         @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  trader              TraderProfile @relation(fields: [traderId], references: [id], onDelete: Cascade)
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions           Position[]

  @@unique([userId, traderId])
  @@index([userId, isActive])
  @@index([traderId, isActive])
  @@map("copy_trading")
}

model Position {
  id                String         @id @default(cuid())
  copyTradingId     String
  tokenMint         String
  tokenSymbol       String
  tokenName         String
  entryTxHash       String
  entryPrice        Float
  entryAmount       Float
  entryValue        Float
  entryTimestamp    DateTime
  exitTxHash        String?
  exitPrice         Float?
  exitAmount        Float?
  exitValue         Float?
  exitTimestamp     DateTime?
  exitReason        String?
  profitLoss        Float?
  profitLossPercent Float?
  feeAmount         Float?
  feeTxHash         String?
  status            PositionStatus @default(OPEN)
  slTpTriggeredAt   DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  copyTrading       CopyTrading    @relation(fields: [copyTradingId], references: [id], onDelete: Cascade)

  @@index([tokenMint, status])
  @@index([status, updatedAt])
  @@index([copyTradingId, status, updatedAt(sort: Desc)])
  @@index([status, exitTimestamp(sort: Desc)])
  @@index([status, slTpTriggeredAt])
  @@index([copyTradingId, tokenMint])
  @@map("positions")
}

model MonitoredWallet {
  id            String                @id @default(cuid())
  walletAddress String                @unique
  traderId      String?
  isActive      Boolean               @default(true)
  lastSeenTx    String?
  lastSeenAt    DateTime?
  totalCopiers  Int                   @default(0)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  transactions  DetectedTransaction[]
  trader        TraderProfile?        @relation(fields: [traderId], references: [id])

  @@index([walletAddress, isActive])
  @@map("monitored_wallets")
}

model DetectedTransaction {
  id                String          @id @default(cuid())
  monitoredWalletId String
  txHash            String          @unique
  type              String
  tokenMint         String
  tokenSymbol       String?
  amount            Float
  price             Float
  totalValue        Float
  processed         Boolean         @default(false)
  copiesCreated     Int             @default(0)
  detectedAt        DateTime        @default(now())
  processedAt       DateTime?
  monitoredWallet   MonitoredWallet @relation(fields: [monitoredWalletId], references: [id])

  @@index([txHash])
  @@index([monitoredWalletId, processed])
  @@index([detectedAt])
  @@map("detected_transactions")
}

model TokenPrice {
  id             String   @id @default(cuid())
  tokenMint      String   @unique
  tokenSymbol    String
  priceUSD       Float
  priceChange24h Float?
  volume24h      Float?
  updatedAt      DateTime @updatedAt

  @@index([tokenMint])
  @@map("token_prices")
}

model ExecutionQueue {
  id            String    @id @default(cuid())
  type          String
  userId        String
  copyTradingId String
  positionId    String?
  tokenMint     String
  amount        Float
  maxSlippage   Float     @default(1)
  status        String    @default("PENDING")
  attempts      Int       @default(0)
  lastError     String?
  txHash        String?
  priority      Int       @default(0)
  createdAt     DateTime  @default(now())
  executedAt    DateTime?

  @@index([status, priority, createdAt])
  @@index([userId])
  @@map("execution_queue")
}

model CustodialWallet {
  id                String   @id @default(cuid())
  userId            String   @unique
  publicKey         String   @unique
  encryptedKey      String
  keyIv             String
  keyTag            String
  keySalt           String?
  keyVersion        Int      @default(1)
  dataKeyCiphertext String?
  dataKeyKeyId      String?
  encryptedMnemonic String?
  mnemonicIv        String?
  mnemonicTag       String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([publicKey])
  @@index([userId, isActive])
  @@map("custodial_wallets")
}

model KeyVersion {
  id        String    @id @default(cuid())
  version   Int       @unique
  algorithm String
  kdfConfig Json
  kmsKeyId  String
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  isActive  Boolean   @default(true)

  @@index([version, isActive])
  @@map("key_versions")
}

model KeyOperationLog {
  id         String   @id @default(cuid())
  operation  String
  keyVersion Int
  userId     String?
  success    Boolean
  errorMsg   String?
  ipAddress  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([operation, createdAt])
  @@index([userId, createdAt])
  @@map("key_operation_logs")
}

model JWTSecretVersion {
  id         String   @id @default(cuid())
  secretHash String   @unique
  version    Int      @unique
  purpose    String   @default("access")
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  isActive   Boolean  @default(true)
  rotatedBy  String?

  @@index([version, isActive])
  @@index([purpose, isActive])
  @@index([expiresAt])
  @@map("jwt_secret_versions")
}

model FinancialAuditLog {
  id           String   @id @default(cuid())
  userId       String
  operation    String
  resourceType String
  resourceId   String
  amount       Float?
  currency     String?
  feeAmount    Float?
  metadata     Json
  ipAddress    String
  userAgent    String?
  previousHash String?
  currentHash  String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([operation, createdAt])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("financial_audit_logs")
}

model DataDeletionRequest {
  id          String    @id @default(cuid())
  userId      String
  reason      String?
  status      String    @default("PENDING")
  processedAt DateTime?
  processedBy String?
  deletedData Json?
  ipAddress   String
  userAgent   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
  @@map("data_deletion_requests")
}

model DataExportRequest {
  id          String    @id @default(cuid())
  userId      String
  format      String    @default("JSON")
  status      String    @default("PENDING")
  fileUrl     String?
  fileSize    Int?
  expiresAt   DateTime?
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
  @@map("data_export_requests")
}

model ConsentLog {
  id          String   @id @default(cuid())
  userId      String
  consentType String
  version     String
  granted     Boolean
  ipAddress   String
  userAgent   String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentType])
  @@index([consentType, createdAt])
  @@map("consent_logs")
}

model KYCVerification {
  id                String    @id @default(cuid())
  userId            String    @unique
  status            String    @default("PENDING")
  tier              Int       @default(1)
  encryptedData     String?
  dataKeyCiphertext String?
  dataKeyKeyId      String?
  keyIv             String?
  keyTag            String?
  keySalt           String?
  keyVersion        Int?
  verifiedAt        DateTime?
  verifiedBy        String?
  rejectionReason   String?
  riskScore         Float?
  riskLevel         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, tier])
  @@index([userId])
  @@map("kyc_verifications")
}

model AMLAlert {
  id              String    @id @default(cuid())
  userId          String
  alertType       String
  severity        String
  description     String
  transactionId   String?
  transactionHash String?
  amount          Float?
  currency        String?
  status          String    @default("OPEN")
  assignedTo      String?
  resolution      String?
  resolvedAt      DateTime?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([alertType, severity])
  @@index([status, createdAt])
  @@map("aml_alerts")
}

model RegulatoryReport {
  id          String   @id @default(cuid())
  reportType  String
  period      String
  fileUrl     String
  fileSize    Int
  fileHash    String
  recordCount Int
  generatedBy String?
  createdAt   DateTime @default(now())

  @@index([reportType, period])
  @@index([createdAt])
  @@map("regulatory_reports")
}

model DeadLetterQueueItem {
  id          String    @id @default(cuid())
  operation   String
  payload     Json
  error       String
  retryCount  Int       @default(0)
  lastRetryAt DateTime?
  nextRetryAt DateTime?
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
  status      String    @default("PENDING")
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([status, nextRetryAt])
  @@index([userId])
  @@map("dead_letter_queue")
}

model Webhook {
  id         String            @id @default(cuid())
  userId     String
  url        String
  events     String[]
  secret     String
  active     Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  deliveries WebhookDelivery[]
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
  @@map("webhooks")
}

model WebhookDelivery {
  id           String   @id @default(cuid())
  webhookId    String
  event        String
  payload      Json?
  status       String
  responseCode Int?
  error        String?
  attempt      Int      @default(1)
  createdAt    DateTime @default(now())
  webhook      Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, createdAt])
  @@index([status, createdAt])
  @@map("webhook_deliveries")
}

