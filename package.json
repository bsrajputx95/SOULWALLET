{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "prebuild": "tsx scripts/check-exposed-secrets.ts",
    "start": "expo start",
    "start:tunnel": "expo start --tunnel",
    "start:web": "expo start --web",
    "start:android": "expo start --android",
    "start:ios": "expo start --ios",
    "server": "node server.js",
    "server:dev": "nodemon server.js",
    "server:build": "tsc --project tsconfig.server.json",
    "server:start": "npm run server:build && node dist/server/fastify.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "copy-trading:start": "tsx src/services/copyTradingMonitor.ts",
    "copy-trading:dev": "nodemon --watch src --ext ts --exec tsx src/services/copyTradingMonitor.ts",
    "copy-trading:pm2": "pm2 start src/services/copyTradingMonitor.ts --name copy-trading --interpreter tsx",
    "dev": "concurrently \"npm run server:dev\" \"npm run start\"",
    "build": "npm run db:generate && npm run server:build",
    "build:web": "expo export --platform web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "test": "jest",
    "test:unit": "jest --testPathPattern=__tests__/unit",
    "test:integration": "jest --testPathPattern=__tests__/integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "rm -rf node_modules dist .expo android/build ios/build",
    "postinstall": "prisma generate",
    "prepare": "husky install || true",
    "validate-env": "tsx scripts/validate-env.ts",
    "deploy:staging": "npm run build && npm run db:migrate:deploy && npm run server:start",
    "deploy:production": "npm run validate-env && npm run build && npm run db:migrate:deploy && npm run server:start",
    "deploy:docker": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d",
    "health:check": "curl -f http://localhost:3001/health || exit 1",
    "health:db": "curl -f http://localhost:3001/health/db || exit 1",
    "health:redis": "curl -f http://localhost:3001/health/redis || exit 1",
    "health:all": "npm run health:check && npm run health:db && npm run health:redis",
    "db:backup": "./scripts/backup-database.sh",
    "db:restore": "./scripts/restore-database.sh",
    "release:notes": "tsx scripts/generate-release-notes.ts",
    "release:tag": "npm version patch && git push --tags",
    "release:major": "npm version major && git push --tags",
    "release:minor": "npm version minor && git push --tags",
    "docker:build": "docker build -t soulwallet-backend .",
    "docker:run": "docker run -p 3001:3001 --env-file .env soulwallet-backend",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f backend",
    "logs:tail": "tail -f logs/combined.log",
    "logs:error": "tail -f logs/error.log",
    "monitor": "pm2 monit"
  },
  "dependencies": {
    "@craftzdog/react-native-buffer": "^6.1.0",
    "@expo-google-fonts/orbitron": "^0.4.1",
    "@expo/vector-icons": "~14.0.4",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@hono/trpc-server": "^0.4.0",
    "@nkzw/create-context-hook": "^1.1.0",
    "@prisma/client": "^6.16.3",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^7.4.2",
    "@react-navigation/native": "^7.1.6",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.98.2",
    "@tanstack/react-query": "^5.83.0",
    "@trpc/client": "^11.6.0",
    "@trpc/react-query": "^11.4.3",
    "@trpc/server": "^11.6.0",
    "@types/bull": "^3.15.9",
    "@types/node-cron": "^3.0.11",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "bull": "^4.16.5",
    "crypto-js": "^4.2.0",
    "ed25519-hd-key": "^1.3.0",
    "expo": "^52.0.47",
    "expo-blur": "~14.0.3",
    "expo-clipboard": "~7.0.1",
    "expo-constants": "~17.0.8",
    "expo-document-picker": "~13.0.3",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.1",
    "expo-image": "~2.0.7",
    "expo-image-picker": "~16.0.6",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.5",
    "expo-location": "~18.0.10",
    "expo-router": "~4.0.21",
    "expo-secure-store": "~14.0.1",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.1",
    "expo-symbols": "~0.2.2",
    "expo-system-ui": "~4.0.9",
    "expo-web-browser": "~14.0.2",
    "fastify": "^5.6.1",
    "hono": "^4.10.3",
    "ioredis": "^5.8.0",
    "isomorphic-dompurify": "^2.31.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react-native": "^0.475.0",
    "metro": "^0.81.0",
    "nativewind": "^4.1.23",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.9",
    "pino": "^9.0.0",
    "pino-pretty": "^11.3.0",
    "prisma": "^6.16.3",
    "process": "^0.11.10",
    "rate-limiter-flexible": "^8.1.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-get-random-values": "~1.11.0",
    "react-native-polyfill-globals": "^3.1.0",
    "react-native-qrcode-svg": "^6.3.16",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-share": "^12.2.0",
    "react-native-svg": "^15.8.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "~0.19.13",
    "readable-stream": "^4.7.0",
    "rotating-file-stream": "^3.2.7",
    "sharp": "^0.34.5",
    "superjson": "^2.2.3",
    "tweetnacl": "^1.0.3",
    "web-streams-polyfill": "^4.1.0",
    "zod": "^4.0.10",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/cli": "^54.0.13",
    "@expo/ngrok": "^4.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.2",
    "@types/react": "~18.3.12",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-plugin-transform-imports": "^2.0.0",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~8.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "husky": "^9.1.6",
    "nodemon": "^3.1.10",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "~5.8.3"
  },
  "overrides": {
    "copy-anything": "^3.0.5"
  },
  "private": true
}
