{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:android": "expo start --android",
    "android": "expo run:android",
    "build:android:beta": "eas build --platform android --profile beta-apk",
    "build:android:production": "eas build --platform android --profile production",
    "server": "node dist/src/server/fastify.js",
    "server:build": "tsc --project tsconfig.server.json && tsc-alias -p tsconfig.server.json",
    "server:prod": "NODE_ENV=production node dist/src/server/fastify.js",
    "server:start": "npm run deploy && npm run server:prod",
    "deploy": "npm run db:generate && npm run server:build && npm run db:migrate:deploy",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "type-check": "tsc --noEmit --project tsconfig.server.json",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "rm -rf node_modules dist .expo android/build",
    "postinstall": "npx patch-package && node -e \"const fs=require('fs');const cp=require('child_process');if(process.env.EAS_BUILD){console.log('Skipping prisma on EAS build');}else if(fs.existsSync('prisma/schema.prisma')){cp.execSync('npx prisma generate',{stdio:'inherit'});}else{console.log('Skipping prisma - schema not found');}\"",
    "test": "jest",
    "test:unit": "jest --testPathPattern=__tests__/unit",
    "test:integration": "jest --testPathPattern=__tests__/integration",
    "copy-trading:start": "tsx src/services/copyTradingMonitor.ts"
  },
