{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "prebuild": "tsx scripts/check-exposed-secrets.ts && npm run type-check && npm run lint",
    "start": "expo start",
    "start:tunnel": "expo start --tunnel",
    "start:web": "expo start --web",
    "start:android": "expo start --android",
    "start:ios": "expo start --ios",
    "server": "node server.js",
    "server:dev": "nodemon server.js",
    "server:build": "tsc --project tsconfig.server.json",
    "server:start": "npm run server:build && node dist/server/fastify.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-traders": "tsx prisma/seed-traders.ts",
    "db:test-connection": "tsx scripts/test-database-connection.ts",
    "db:verify-schema": "tsx scripts/verify-schema-alignment.ts",
    "db:create-migration": "bash scripts/create-production-migration.sh",
    "db:health": "curl -f http://localhost:3001/health/db || exit 1",
    "db:reset": "prisma migrate reset",
    "copy-trading:start": "tsx src/services/copyTradingMonitor.ts",
    "copy-trading:dev": "nodemon --watch src --ext ts --exec tsx src/services/copyTradingMonitor.ts",
    "copy-trading:pm2": "pm2 start src/services/copyTradingMonitor.ts --name copy-trading --interpreter tsx",
    "dev": "concurrently \"npm run server:dev\" \"npm run start\"",
    "build": "npm run db:generate && npm run server:build",
    "build:web": "expo export --platform web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "test": "jest",
    "test:unit": "jest --testPathPattern=__tests__/unit",
    "test:integration": "jest --testPathPattern=__tests__/integration",
    "test:integration:full": "tsx __tests__/scripts/run-all-tests.ts",
    "test:auth": "jest __tests__/integration/auth.test.ts",
    "test:wallet": "jest __tests__/integration/wallet.test.ts",
    "test:copy-trading": "jest __tests__/integration/copy-trading.test.ts",
    "test:market": "jest __tests__/integration/market.test.ts",
    "test:social": "jest __tests__/integration/social.test.ts",
    "test:swap": "jest __tests__/integration/swap.test.ts",
    "test:transaction": "jest __tests__/integration/transaction.test.ts",
    "test:portfolio": "jest __tests__/integration/portfolio.test.ts",
    "test:health": "jest __tests__/integration/health-checks.test.ts",
    "test:errors": "jest __tests__/integration/error-handling.test.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:security": "jest --testPathPattern=__tests__/security",
    "test:property": "jest --testPathPattern=__tests__/property",
    "test:chaos": "jest --testPathPattern=__tests__/chaos",
    "test:chaos:db": "jest __tests__/chaos/database-failure.test.ts",
    "test:chaos:rpc": "jest __tests__/chaos/rpc-failure.test.ts",
    "test:chaos:redis": "jest __tests__/chaos/redis-failure.test.ts",
    "test:chaos:pod": "jest __tests__/chaos/pod-failure.test.ts",
    "test:chaos:report": "tsx scripts/generate-chaos-report.ts",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "type-check": "tsc --noEmit --project tsconfig.server.json",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "rm -rf node_modules dist .expo android/build ios/build",
    "postinstall": "node -e \"const fs=require('fs');const cp=require('child_process');if(process.env.EAS_BUILD){console.log('Skipping prisma on EAS build');}else if(fs.existsSync('prisma/schema.prisma')){cp.execSync('npx prisma generate',{stdio:'inherit'});}else{console.log('Skipping prisma - schema not found');}\"",
    "prepare": "husky install || true",
    "validate-env": "tsx scripts/validate-env.ts",
    "deploy:staging": "npm run build && npm run db:migrate:deploy && npm run server:start",
    "deploy:production": "npm run validate-env && npm run db:test-connection && npm run build && npm run db:migrate:deploy && npm run server:start",
    "deploy:docker": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d",
    "health:check": "curl -f http://localhost:3001/health || exit 1",
    "health:db": "curl -f http://localhost:3001/health/db || exit 1",
    "health:redis": "curl -f http://localhost:3001/health/redis || exit 1",
    "health:all": "npm run health:check && npm run health:db && npm run health:redis",
    "health:test": "tsx scripts/test-health-endpoints.ts",
    "health:monitor": "tsx scripts/monitor-health.ts",
    "sentry:test-config": "tsx scripts/test-sentry-config.ts",
    "db:backup": "./scripts/backup-database.sh",
    "db:restore": "./scripts/restore-database.sh",
    "release:notes": "tsx scripts/generate-release-notes.ts",
    "release:tag": "npm version patch && git push --tags",
    "release:major": "npm version major && git push --tags",
    "release:minor": "npm version minor && git push --tags",
    "docker:build": "docker build -t soulwallet-backend .",
    "docker:run": "docker run -p 3001:3001 --env-file .env soulwallet-backend",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f backend",
    "logs:tail": "tail -f logs/combined.log",
    "logs:error": "tail -f logs/error.log",
    "monitor": "pm2 monit",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "version:patch": "node scripts/bump-version.js --patch",
    "version:minor": "node scripts/bump-version.js --minor",
    "version:major": "node scripts/bump-version.js --major",
    "analyze:build-size": "node scripts/analyze-build-size.js --latest",
    "analyze:apk": "node scripts/analyze-build-size.js --apk",
    "analyze:aab": "node scripts/analyze-build-size.js --aab",
    "test:android": "bash scripts/test-android-build.sh --profile beta-apk",
    "test:android:full": "bash scripts/test-android-build.sh --profile production --api-levels 24,29,34",
    "test:android:quick": "bash scripts/test-android-build.sh --quick",
    "optimize:assets": "bash scripts/optimize-assets.sh",
    "optimize:icons": "bash scripts/optimize-assets.sh --icons-only",
    "optimize:webp": "bash scripts/optimize-assets.sh --webp-only",
    "build:android:beta": "eas build --platform android --profile beta-apk",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:production": "eas build --platform android --profile production",
    "build:android:local": "eas build --platform android --profile beta-apk --local",
    "submit:android": "eas submit --platform android --profile production",
    "submit:android:beta": "eas submit --platform android --profile beta-apk",
    "keys:status": "tsx scripts/check-key-status.ts",
    "keys:rotate-master": "tsx scripts/rotate-master-key.ts",
    "keys:rotate-jwt": "tsx scripts/rotate-jwt-secrets.ts",
    "keys:rollback": "tsx scripts/emergency-key-rollback.ts",
    "keys:migrate": "tsx -e \"require('./src/lib/services/keyMigration').KeyMigrationService.prototype.migrateWallets().then(console.log)\"",
    "load-test": "k6 run tests/load/api-load-test.js",
    "load-test:spike": "k6 run tests/load/spike-test.js",
    "load-test:stress": "k6 run tests/load/stress-test.js",
    "load-test:production": "k6 run tests/load/production-load-test.js",
    "load-test:soak": "k6 run tests/load/soak-test.js",
    "profile:api": "bash scripts/profile-api.sh",
    "profile:doctor": "clinic doctor -- node dist/server/fastify.js",
    "profile:flame": "clinic flame -- node dist/server/fastify.js",
    "profile:heap": "clinic heapprofiler -- node dist/server/fastify.js",
    "profile:memory": "bash scripts/profile-memory.sh",
    "bench": "autocannon -c 100 -d 30 http://localhost:3001/health",
    "verify:security": "bash scripts/verify-production-security.sh",
    "verify:failover": "bash scripts/test-failover.sh",
    "verify:observability": "bash scripts/verify-observability.sh",
    "verify:all": "npm run verify:security && npm run verify:observability && npm run health:test && npm run load-test",
    "security:scan": "snyk test --all-projects --severity-threshold=high",
    "security:monitor": "snyk monitor --all-projects",
    "metrics:view": "echo 'Opening Prometheus...' && start http://localhost:9090",
    "traces:view": "echo 'Opening Jaeger...' && start http://localhost:16686",
    "logs:view": "echo 'Opening Kibana...' && start http://localhost:5601",
    "dashboards:view": "echo 'Opening Grafana...' && start http://localhost:3000",
    "observability:up": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d prometheus alertmanager jaeger elasticsearch logstash kibana grafana",
    "observability:down": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml stop prometheus alertmanager jaeger elasticsearch logstash kibana grafana",
    "analyze:bundle": "npx react-native-bundle-visualizer",
    "analyze:deps": "npx depcheck",
    "test:e2e:build:android": "detox build -c android.emu.debug",
    "test:e2e:run:android": "detox test -c android.emu.debug",
    "test:e2e:build:ios": "detox build -c ios.sim.debug",
    "test:e2e:run:ios": "detox test -c ios.sim.debug",
    "optimize:images": "bash scripts/optimize-images.sh",
    "load-test:extreme": "k6 run tests/load/extreme-load-test.js"
  },
