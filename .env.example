# Database Configuration
DATABASE_URL=file:./dev.db
# For production PostgreSQL: postgresql://user:password@localhost:5432/soulwallet
REDIS_URL=redis://localhost:6379

# Expo Public Variables (Available to client-side)
EXPO_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
EXPO_PUBLIC_JUPITER_API_URL=https://quote-api.jup.ag/v6
EXPO_PUBLIC_DEV_MODE=true
EXPO_PUBLIC_LOG_LEVEL=info
EXPO_PUBLIC_ENABLE_SOCIAL_FEATURES=true
EXPO_PUBLIC_MAX_POST_LENGTH=280
EXPO_PUBLIC_DEFAULT_SLIPPAGE=0.5
EXPO_PUBLIC_MAX_PRIORITY_FEE=0.01
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
EXPO_PUBLIC_ANALYTICS_ID=your-analytics-id-here

# Cache Configuration
PRICE_CACHE_TTL=60
DASHBOARD_CACHE_TTL=15
MARKET_LIST_TTL=60
TOKEN_DETAIL_TTL=60
RUG_CACHE_TTL=300

# Security Configuration
MIN_LIQUIDITY_USD=10000
MIN_TOKEN_AGE_HOURS=24
MAX_OWNER_CONCENTRATION=0.5

# Solana RPC Configuration (used by backend)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Copy Trading Configuration
HELIUS_API_KEY=your-helius-api-key-here
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-helius-api-key-here
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=your-helius-api-key-here
WALLET_ENCRYPTION_KEY=your-wallet-encryption-key-at-least-32-characters-long
HEALTH_CHECK_PORT=3002

# Feature Flags
FEATURE_COPY_TRADING_ENABLED=true
FEATURE_SEND_ENABLED=true
FEATURE_SWAP_ENABLED=true
FEATURE_SIMULATION_MODE=false

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_EXP_SECONDS=3600

# Admin Configuration
ADMIN_KEY=your-admin-key-change-this
ADMIN_API_KEY=your-admin-api-key-change-this
# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin@example.com

# Server Configuration
PORT=3001
NODE_ENV=development
HOST=0.0.0.0
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006
CSRF_ENABLED=false

# Email Configuration
EMAIL_PROVIDER=console
# Options: "smtp", "sendgrid", "resend", "console"

# SMTP Configuration (if EMAIL_PROVIDER="smtp")
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SendGrid Configuration (if EMAIL_PROVIDER="sendgrid")
SENDGRID_API_KEY=your-sendgrid-api-key

# Resend Configuration (if EMAIL_PROVIDER="resend")
RESEND_API_KEY=your-resend-api-key

# Email Settings
EMAIL_FROM=noreply@soulwallet.com
EMAIL_FROM_NAME=SoulWallet

# Authentication Security Settings
BCRYPT_ROUNDS=12
OTP_EXPIRES_IN_MINUTES=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
ACCOUNT_LOCKOUT_DURATION_MINUTES=30

# Session Configuration
SESSION_CLEANUP_INTERVAL_HOURS=24
SESSION_TIMEOUT_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=7
MAX_SESSIONS_PER_USER=5
SESSION_FINGERPRINT_STRICT=false

# Security Features
ENABLE_SUSPICIOUS_LOGIN_ALERTS=true
ENABLE_ACCOUNT_LOCKOUT_NOTIFICATIONS=true
ENABLE_SESSION_ACTIVITY_LOGGING=true
ENABLE_GEOLOCATION_TRACKING=false

# Cleanup Service Configuration
CLEANUP_EXPIRED_SESSIONS_HOURS=24
CLEANUP_OLD_LOGIN_ATTEMPTS_DAYS=30
CLEANUP_SESSION_ACTIVITIES_DAYS=90
CLEANUP_EXPIRED_OTPS_HOURS=1
AUTO_UNLOCK_EXPIRED_ACCOUNTS=true

# Development Settings
ENABLE_PLAYGROUND=true
ENABLE_INTROSPECTION=true
