# Database Configuration
DATABASE_URL=file:./dev.db
# For production PostgreSQL: postgresql://user:password@localhost:5432/soulwallet
REDIS_URL=redis://localhost:6379

# Expo Public Variables (Available to client-side)
EXPO_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
EXPO_PUBLIC_JUPITER_API_URL=https://quote-api.jup.ag/v6
EXPO_PUBLIC_DEV_MODE=true
EXPO_PUBLIC_LOG_LEVEL=info
EXPO_PUBLIC_ENABLE_SOCIAL_FEATURES=true
EXPO_PUBLIC_MAX_POST_LENGTH=280
EXPO_PUBLIC_DEFAULT_SLIPPAGE=0.5
EXPO_PUBLIC_MAX_PRIORITY_FEE=0.01
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
EXPO_PUBLIC_ANALYTICS_ID=your-analytics-id-here

# Cache Configuration
PRICE_CACHE_TTL=60
DASHBOARD_CACHE_TTL=15
MARKET_LIST_TTL=60
TOKEN_DETAIL_TTL=60
RUG_CACHE_TTL=300

# Security Configuration
MIN_LIQUIDITY_USD=10000
MIN_TOKEN_AGE_HOURS=24
MAX_OWNER_CONCENTRATION=0.5

# Solana RPC Configuration (used by backend)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Copy Trading Configuration
HELIUS_API_KEY=your-helius-api-key-here
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-helius-api-key-here
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=your-helius-api-key-here
WALLET_ENCRYPTION_KEY=your-wallet-encryption-key-at-least-32-characters-long
HEALTH_CHECK_PORT=3002

# Custodial Wallet Key Management
# IMPORTANT: In production, KMS_PROVIDER MUST be 'aws' or 'vault' (not 'env')
# Using KMS_PROVIDER=env in production will cause startup to fail
KMS_PROVIDER=env

# AWS KMS Configuration (required if KMS_PROVIDER=aws)
AWS_REGION=us-east-1
AWS_KMS_KEY_ID=alias/soulwallet-master-key
# AWS credentials are loaded from environment or IAM role
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# HashiCorp Vault Configuration (required if KMS_PROVIDER=vault)
# VAULT_ADDR=https://vault.example.com:8200
# VAULT_TOKEN=s.xxxxxxxxxx
# VAULT_TRANSIT_KEY=soulwallet-key

# Key audit logging (recommended for production)
ENABLE_KEY_AUDIT_LOGGING=false

# Development-only: These are ignored when using AWS/Vault KMS
# DO NOT use these in production
CUSTODIAL_WALLET_MASTER_SECRET=
CUSTODIAL_WALLET_SALT=
TOTP_ENCRYPTION_KEY=

# Feature Flags
FEATURE_COPY_TRADING_ENABLED=true
FEATURE_SEND_ENABLED=true
FEATURE_SWAP_ENABLED=true
FEATURE_SIMULATION_MODE=false

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-32-characters-long
JWT_EXPIRES_IN=5m
JWT_REFRESH_EXPIRES_IN=24h
JWT_EXP_SECONDS=3600

# Admin Configuration
ADMIN_KEY=your-admin-key-change-this
ADMIN_API_KEY=your-admin-api-key-change-this
# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin@example.com

# Server Configuration
PORT=3001
NODE_ENV=development
HOST=0.0.0.0
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006
CSRF_ENABLED=true

# Email Configuration
EMAIL_PROVIDER=console
# Options: "smtp", "sendgrid", "resend", "console"

# SMTP Configuration (if EMAIL_PROVIDER="smtp")
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SendGrid Configuration (if EMAIL_PROVIDER="sendgrid")
SENDGRID_API_KEY=your-sendgrid-api-key

# Resend Configuration (if EMAIL_PROVIDER="resend")
RESEND_API_KEY=your-resend-api-key

# Email Settings
EMAIL_FROM=noreply@soulwallet.com
EMAIL_FROM_NAME=SoulWallet

# Authentication Security Settings
BCRYPT_ROUNDS=12
OTP_EXPIRES_IN_MINUTES=10
MAX_LOGIN_ATTEMPTS=3
LOCKOUT_DURATION_MINUTES=15
ACCOUNT_LOCKOUT_DURATION_MINUTES=60

# CAPTCHA (hCaptcha by default)
CAPTCHA_ENABLED=true
CAPTCHA_PROVIDER=hcaptcha
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Session Configuration
SESSION_CLEANUP_INTERVAL_HOURS=24
SESSION_TIMEOUT_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=7
MAX_SESSIONS_PER_USER=2
SESSION_FINGERPRINT_STRICT=true

# Security Features
ENABLE_SUSPICIOUS_LOGIN_ALERTS=true
ENABLE_ACCOUNT_LOCKOUT_NOTIFICATIONS=true
ENABLE_SESSION_ACTIVITY_LOGGING=true
ENABLE_GEOLOCATION_TRACKING=false
ENABLE_LOGIN_NOTIFICATIONS=true

# Geo-blocking (compliance)
GEO_BLOCKING_ENABLED=true

# Cleanup Service Configuration
CLEANUP_EXPIRED_SESSIONS_HOURS=24
CLEANUP_OLD_LOGIN_ATTEMPTS_DAYS=30
CLEANUP_SESSION_ACTIVITIES_DAYS=90
CLEANUP_EXPIRED_OTPS_HOURS=1
AUTO_UNLOCK_EXPIRED_ACCOUNTS=true

# Development Settings
ENABLE_PLAYGROUND=true
ENABLE_INTROSPECTION=true

# ========================================
# Plan5: DoS Protection & Rate Limiting
# ========================================

# Request Queue Configuration
MAX_CONCURRENT_REQUESTS_PER_USER=50
MAX_CONCURRENT_REQUESTS_PER_IP=100
MAX_QUEUE_DEPTH=1000
QUEUE_TIMEOUT_MS=30000

# Adaptive Rate Limiting
ENABLE_ADAPTIVE_RATE_LIMITING=true
ATTACK_DETECTION_THRESHOLD=0.10
ATTACK_DETECTION_WINDOW_MINUTES=5
ADAPTATION_RESTORE_MINUTES=30

# Trusted IPs for rate limit bypass
# Comma-separated list of IPs or CIDR ranges
TRUSTED_IPS=127.0.0.1,::1
ENABLE_TRUSTED_IP_BYPASS=true

# Alert Configuration
ENABLE_RATE_LIMIT_ALERTS=true
ALERT_EMAIL_RECIPIENTS=admin@example.com
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_SECRET=
ALERT_THROTTLE_MINUTES=5
ALERT_MIN_SEVERITY=WARNING
ALERT_WEBHOOK_RETRY_ATTEMPTS=3

# Database Connection Pool Configuration
DB_CONNECTION_LIMIT=20
DB_POOL_TIMEOUT=30
DB_CONNECT_TIMEOUT=10
ENABLE_POOL_MONITORING=true
POOL_ALERT_THRESHOLD=0.9

# ========================================
# Plan8: Redis Cache Configuration
# ========================================

# Redis Connection
REDIS_CLUSTER_MODE=false
REDIS_MAX_RETRIES=3
REDIS_CONNECT_TIMEOUT=10000

# Cache TTL Configuration (seconds)
CACHE_TTL_SESSION=86400        # 24 hours - session data
CACHE_TTL_PRICE=60             # 1 minute - price data
CACHE_TTL_PORTFOLIO=300        # 5 minutes - portfolio snapshots
CACHE_TTL_TOKEN_METADATA=3600  # 1 hour - token metadata

# External Call Timeout (milliseconds)
EXTERNAL_CALL_TIMEOUT=5000     # 5 seconds - Plan7 timeout

# ========================================
# Plan9: Database Scaling Configuration
# ========================================

# Read Replica (optional - for scaling reads)
DATABASE_READ_REPLICA_URL=

# PgBouncer Connection (optional - for connection pooling)
PGBOUNCER_URL=

# ========================================
# RabbitMQ Configuration
# ========================================
RABBITMQ_URL=amqp://soulwallet:rabbitmq_password@localhost:5672
RABBITMQ_USER=soulwallet
RABBITMQ_PASSWORD=rabbitmq_password
RABBITMQ_PREFETCH=10
RABBITMQ_RETRY_ATTEMPTS=3
RABBITMQ_RETRY_DELAY_MS=5000

# ========================================
# Database Encryption Configuration
# ========================================
# 32-byte hex key for pgcrypto column encryption (64 hex chars)
# Generate with: openssl rand -hex 32
PGCRYPTO_KEY=
# Optional salt for key derivation (if using passphrase instead of hex key)
PGCRYPTO_SALT=
# Path to TDE encryption key file (used by init script)
POSTGRES_DATA_ENCRYPTION_KEY_PATH=/var/lib/postgresql/encryption/data_encryption.key

# ========================================
# WAL Archiving & PITR Configuration
# ========================================
# Enable WAL backup to S3 (requires AWS CLI configured)
ENABLE_WAL_S3_BACKUP=false
# S3 bucket for WAL and backup storage
S3_BUCKET=soulwallet-backups
# Days to retain WAL files locally
WAL_ARCHIVE_RETENTION_DAYS=7

# ========================================
# GDPR Deletion Configuration
# ========================================
# Grace period before processing deletion requests (GDPR compliance)
GDPR_DELETION_GRACE_PERIOD_DAYS=30
# Maximum deletion requests to process per cron run
GDPR_DELETION_BATCH_SIZE=10

# ========================================
# PostgreSQL Replication Configuration
# ========================================
# Replication user for read replica
POSTGRES_REPLICATION_USER=replicator
# Replication password (generate with: openssl rand -base64 24)
POSTGRES_REPLICATION_PASSWORD=

# ========================================
# Feature Flags (Unleash)
# ========================================
# Feature flag provider: local, unleash, launchdarkly
FEATURE_FLAG_PROVIDER=local
# Unleash API URL (if using Unleash)
UNLEASH_API_URL=http://localhost:4242/api
# Unleash API key
UNLEASH_API_KEY=
# LaunchDarkly SDK key (if using LaunchDarkly)
LAUNCHDARKLY_SDK_KEY=

# ========================================
# HashiCorp Vault Configuration
# ========================================
# Vault server address
VAULT_ADDR=http://localhost:8200
# Vault authentication token (for development only)
VAULT_TOKEN=
# AppRole authentication (recommended for production)
VAULT_ROLE_ID=
VAULT_SECRET_ID=
# Vault namespace (if using Enterprise)
VAULT_NAMESPACE=

# Social Feed Configuration
# Comma-separated list of usernames whose posts appear in all feeds
GLOBAL_POSTER_USERNAMES=bhavanisingh,soulwallet

# Security Configuration (Anti-Exploit)
ENABLE_ROOT_DETECTION=true
ENABLE_DEBUGGER_DETECTION=true
ENABLE_EMULATOR_DETECTION=true
ENABLE_SSL_PINNING=true
BIOMETRIC_THRESHOLD_USD=1000
MAX_EXPLOIT_ATTEMPTS=3
AUTO_BAN_DURATION_HOURS=24
