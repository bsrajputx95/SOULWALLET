# ==========================================
# Soul Wallet - Environment Configuration
# ==========================================

# Required: Backend API URL
EXPO_PUBLIC_API_URL=http://localhost:3000

# Required: Helius RPC API Key (for swaps/transactions)
# Get your key at: https://helius.xyz/
EXPO_PUBLIC_HELIUS_API_KEY=your_helius_key_here

# Optional: Solana RPC URL (defaults to Helius)
EXPO_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: Jupiter API URL
EXPO_PUBLIC_JUPITER_API_URL=https://quote-api.jup.ag/v6

# Optional: Development mode (enables debug logging)
EXPO_PUBLIC_DEV_MODE=true

# Optional: Default slippage for swaps (0.5%)
EXPO_PUBLIC_DEFAULT_SLIPPAGE=0.5

# Optional: Social features (posts, comments, likes)
EXPO_PUBLIC_ENABLE_SOCIAL_FEATURES=true
EXPO_PUBLIC_MAX_POST_LENGTH=280
