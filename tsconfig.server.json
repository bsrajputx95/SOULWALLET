{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "outDir": "./dist",
        "rootDir": ".",
        "strict": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "noEmit": false,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./*"
            ],
            "@server/*": [
                "./src/server/*"
            ],
            "@lib/*": [
                "./src/lib/*"
            ],
            "@services/*": [
                "./src/services/*"
            ]
        }
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "__tests__",
        "dist",
        "*.test.ts",
        "*.spec.ts",
        "app",
        "components",
        "hooks",
        "lib",
        "constants",
        "utils",
        "src/**/*.native.ts",
        "src/**/*.native.tsx"
    ]
}