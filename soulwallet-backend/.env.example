# ==========================================
# Soul Wallet Backend - Environment Configuration
# ==========================================

# Required: Database connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:pass@localhost:5432/soulwallet

# Required: JWT Secret for authentication (32+ characters recommended)
JWT_SECRET=your-super-secret-jwt-key-here-min-32-chars

# Required: Solana RPC endpoint (Helius recommended)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Optional: Additional Helius RPC URLs for load balancing
HELIUS_RPC_URL_2=
HELIUS_RPC_URL_3=
HELIUS_RPC_URL_4=

# Optional: Helius webhook configuration
HELIUS_AUTH_HEADER=your-webhook-secret
HELIUS_WEBHOOK_URL=https://your-api-domain.com/webhooks/helius

# Optional: Jupiter Limit Orders API
JUPITER_LIMIT_API=https://jup.ag/api/limit/v1

# Optional: Server port (defaults to 3000)
PORT=3000
