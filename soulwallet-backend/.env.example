# Required Variables (set these in Railway dashboard)
DATABASE_URL=
JWT_SECRET=
PORT=3000

# Helius Configuration
# Get your API key from: https://helius.xyz/
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key={YOUR_HELIUS_API_KEY}
HELIUS_AUTH_HEADER={YOUR_HELIUS_AUTH_HEADER}
HELIUS_WEBHOOK_URL={YOUR_WEBHOOK_URL}

# Jupiter Limit Order API
JUPITER_LIMIT_API=https://jup.ag/api/limit/v1
