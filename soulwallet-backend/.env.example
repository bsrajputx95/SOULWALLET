# Required Variables (set these in Railway dashboard)
DATABASE_URL=
JWT_SECRET=
PORT=3000

# Helius Configuration - Multiple API Keys for Load Balancing
# Get your API keys from: https://helius.xyz/ (create multiple projects for higher rate limits)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key={YOUR_HELIUS_API_KEY_1}
HELIUS_RPC_URL_2=https://mainnet.helius-rpc.com/?api-key={YOUR_HELIUS_API_KEY_2}
HELIUS_RPC_URL_3=https://mainnet.helius-rpc.com/?api-key={YOUR_HELIUS_API_KEY_3}
HELIUS_RPC_URL_4=https://mainnet.helius-rpc.com/?api-key={YOUR_HELIUS_API_KEY_4}
HELIUS_AUTH_HEADER={YOUR_HELIUS_AUTH_HEADER}
HELIUS_WEBHOOK_URL={YOUR_WEBHOOK_URL}

# Jupiter Limit Order API
JUPITER_LIMIT_API=https://jup.ag/api/limit/v1
