// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  password     String
  firstName    String?
  lastName     String?
  phone        String?
  dateOfBirth  String?  // YYYY-MM-DD format
  profileImage String?  // URL to image
  currency     String   @default("USD")
  language     String   @default("en")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Social Stats
  following   Int      @default(0)
  followers   Int      @default(0)
  roi30d      Float?
  winRate     Float?
  maxDrawdown Float?
  followersEquity Float?

  // Wallet Relation (1-to-1)
  wallet       Wallet?
  copyWallet   CopyWallet?
  
  // Transaction History
  transactions Transaction[]

  // Copy Trading Relations
  copyTradingConfig CopyTradingConfig?
  copyPositions     CopyPosition[]
  copyTradeQueue    CopyTradeQueue[]

  // Social Relations
  posts         Post[]
  likes         Like[]
  comments      Comment[]
  followingRel  Follow[] @relation("following")
  followersRel  Follow[] @relation("followers")

  // IBUY Relations
  settings          UserSettings?
  ibuyPositions     IBuyPosition[] @relation("buyer")
  creatorPositions  IBuyPosition[] @relation("creator")
  creatorRevenues   CreatorRevenue[]
  votes             Vote[]

  @@index([username])
  @@index([email])
}

model Wallet {
  id            String   @id @default(cuid())
  userId        String   @unique
  publicKey     String   @unique
  network       String   @default("mainnet-beta")
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([publicKey])
  @@map("wallets")
}

model CopyWallet {
  id                  String   @id @default(cuid())
  userId              String   @unique
  publicKey           String   @unique
  encryptedPrivateKey String
  status              String   @default("active") // "active", "paused"
  allocatedAmount     Float    @default(0)
  availableAmount     Float    @default(0)
  reservedAmount      Float    @default(0)
  lastBalanceCheckAt  DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  config              CopyTradingConfig?

  @@index([status])
  @@index([userId, status])
  @@map("copy_wallets")
}

model Transaction {
  id            String   @id @default(cuid())
  userId        String
  signature     String   @unique
  type          String   // "send" or "receive"
  amount        Float
  token         String   // "SOL", "USDC", etc.
  fromAddress   String?
  toAddress     String?
  fee           Float    @default(0.000005)
  status        String   @default("pending") // "pending", "confirmed", "failed"
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([signature])
  @@map("transactions")
}

// Copy Trading Models
model CopyTradingConfig {
  id                  String   @id @default(cuid())
  userId              String   @unique
  copyWalletId        String?  @unique
  name                String?  // User-defined label (e.g. "ELON's wallet")
  traderAddress       String   // The wallet address being copied
  totalInvestment     Float    // Max total budget (e.g., 1000 USDC)
  perTradeAmount      Float    // Amount per copy trade (e.g., 100 USDC)
  stopLossPercent     Float    @default(10)  // SL percentage (e.g., 10 = 10% loss)
  takeProfitPercent   Float    @default(30)  // TP percentage (e.g., 30 = 30% profit)
  exitWithTrader      Boolean  @default(true) // Auto-exit when trader exits
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  copyWallet          CopyWallet? @relation(fields: [copyWalletId], references: [id], onDelete: SetNull)
  positions           CopyPosition[]
  queueItems          CopyTradeQueue[]

  @@index([traderAddress])
  @@index([userId, isActive])
  @@map("copy_trading_configs")
}

model CopyPosition {
  id                  String   @id @default(cuid())
  configId            String
  userId              String
  traderTxSignature   String   @unique // Original trader's transaction signature
  inputMint           String   // Token bought (address)
  inputSymbol         String   // Token symbol
  outputMint          String   // Token spent to buy (usually USDC or SOL)
  outputSymbol        String
  entryAmount         Float    // Amount spent (outputAmount)
  tokenAmount         Float    // Amount of tokens received
  entryPrice          Float    // Price at entry (in USDC)
  slPrice             Float?   // Stop loss price
  tpPrice             Float?   // Take profit price
  slOrderId           String?  // Jupiter Limit Order ID for SL
  tpOrderId           String?  // Jupiter Limit Order ID for TP
  cancelTransactions  String?  // JSON string of cancel transactions for client to sign
  status              String   @default("open") // "open", "pending_exit", "pending_cancel", "closed", "sl_hit", "tp_hit"
  closedAt            DateTime?
  createdAt           DateTime @default(now())

  config              CopyTradingConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([configId, status])
  @@index([userId, status])
  @@map("copy_positions")
}

model TraderActivity {
  id              String   @id @default(cuid())
  traderAddress   String
  txSignature     String   @unique
  swapType        String   // "buy" or "sell"
  inputMint       String
  outputMint      String
  inputAmount     Float
  outputAmount    Float
  timestamp       DateTime
  createdAt       DateTime @default(now())

  @@index([traderAddress])
  @@index([timestamp])
  @@map("trader_activity")
}

model CopyTradeQueue {
  id                String   @id @default(cuid())
  configId          String
  userId            String
  positionId        String?  // Set for exit trades, null for entry trades
  idempotencyKey    String?  @unique
  traderTxSignature String
  traderAddress     String
  type              String   @default("entry") // "entry" (buy) or "exit" (sell)
  inputMint         String   // For entry: token bought; For exit: token sold
  inputSymbol       String
  outputMint        String   // For entry: token spent; For exit: token received
  outputSymbol      String
  inputAmount       Float    // For entry: amount received; For exit: amount sold
  outputAmount      Float    // For entry: amount spent; For exit: amount received
  entryPrice        Float
  slPrice           Float?
  tpPrice           Float?
  cancelTransactions String? // JSON string of SL/TP cancel transactions for client to sign (exit trades only)
  status            String   @default("pending") // "pending", "processing", "completed", "failed", "expired", "cancelled"
  retryCount        Int      @default(0)
  maxRetries        Int      @default(3)
  lockedBy          String?
  lockedAt          DateTime?
  processingStartedAt DateTime?
  processedAt       DateTime?
  failedAt          DateTime?
  failureReason     String?
  txSignature       String?
  webhookReceivedAt DateTime?
  enqueueLatencyMs  Int?
  submitLatencyMs   Int?
  expiresAt         DateTime
  createdAt         DateTime @default(now())

  config            CopyTradingConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Unique constraint: entry trades use userId+traderTxSignature, exit trades use positionId
  // Note: Using a unique constraint name to avoid conflicts
  @@unique(name: "unique_queue_item", [userId, traderTxSignature, positionId])
  @@index([userId, status])
  @@index([configId, status])
  @@index([status, createdAt])
  @@index([positionId])
  @@index([expiresAt])
  @@map("copy_trade_queue")
}

model TraderWebhook {
  id            String   @id @default(cuid())
  traderAddress String   @unique
  webhookId     String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([traderAddress])
  @@map("trader_webhooks")
}

model Post {
  id              String   @id @default(cuid())
  userId          String
  content         String   @db.Text
  visibility      String   @default("public") // public | followers | vip
  tokenAddress    String?
  tokenSymbol     String?
  tokenName       String?
  tokenVerified   Boolean  @default(false)
  tokenPriceAtPost Float?
  ibuyCount       Int      @default(0)
  ibuyVolume      Float    @default(0)
  likesCount      Int      @default(0)
  commentsCount   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes           Like[]
  comments        Comment[]
  ibuys           IBuyPosition[]
  votes           Vote[]

  @@index([userId, createdAt])
  @@index([visibility, createdAt])
  @@index([tokenAddress])
  @@map("posts")
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@map("likes")
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("comments")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User     @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

// Vote/Agree-Disagree Model
model Vote {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  type      String   // "agree" or "disagree"
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId]) // One vote per user per post
  @@index([postId])
  @@index([userId])
  @@map("votes")
}

// IBUY Models
model UserSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  ibuySlippage    Int      @default(50)  // 0.5% in bps
  ibuyDefaultSol  Float    @default(0.1)
  autoApprove     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_settings")
}

model IBuyPosition {
  id                String   @id @default(cuid())
  userId            String
  postId            String
  creatorId         String
  tokenAddress      String
  tokenSymbol       String
  entryPrice        Float
  solAmount         Float
  tokenAmount       Float
  creatorFee        Float    @default(0)
  remainingAmount   Float
  realizedPnl       Float    @default(0)
  creatorSharePaid  Float    @default(0)
  status            String   @default("open") // "open", "closed"
  createdAt         DateTime @default(now())
  closedAt          DateTime?

  user              User     @relation("buyer", fields: [userId], references: [id], onDelete: Cascade)
  creator           User     @relation("creator", fields: [creatorId], references: [id], onDelete: Cascade)
  post              Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([creatorId])
  @@index([postId])
  @@map("ibuy_positions")
}

model CreatorRevenue {
  id          String   @id @default(cuid())
  creatorId   String
  positionId  String
  amount      Float
  type        String   // "ibuy_fee" | "profit_share"
  createdAt   DateTime @default(now())

  creator     User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId, createdAt])
  @@map("creator_revenues")
}

// iBuy Queue for handling viral post scenarios
model IBuyQueue {
  id                String   @id @default(cuid())
  userId            String
  postId            String
  amount            Float
  status            String   @default("pending") // pending | processing | completed | failed
  retryCount        Int      @default(0)
  maxRetries        Int      @default(3)
  quote             String?  // JSON string of Jupiter quote
  errorMessage      String?
  processingStartedAt DateTime?
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  
  // Result fields
  positionId        String?  // Set when completed
  tokenAmount       Float?
  creatorFee        Float?

  @@index([status, createdAt])
  @@index([postId, status])
  @@index([userId])
  @@map("ibuy_queue")
}
