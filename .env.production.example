# Database Configuration
# Use managed database service (AWS RDS, DigitalOcean, Railway) for reliability
DATABASE_URL=postgresql://username:password@host:port/database?schema=public&sslmode=require
# Required for distributed rate limiting and caching in production
REDIS_URL=redis://username:password@host:port

# Expo Public Variables (Available to client-side)
# Use premium RPC provider (Helius, QuickNode, Alchemy) - Free public RPCs are rate-limited and unreliable for production
EXPO_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
EXPO_PUBLIC_JUPITER_API_URL=https://quote-api.jup.ag/v6
EXPO_PUBLIC_DEV_MODE=false
EXPO_PUBLIC_LOG_LEVEL=warn
EXPO_PUBLIC_ENABLE_SOCIAL_FEATURES=true
EXPO_PUBLIC_MAX_POST_LENGTH=280
EXPO_PUBLIC_DEFAULT_SLIPPAGE=0.5
EXPO_PUBLIC_MAX_PRIORITY_FEE=0.01
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
EXPO_PUBLIC_ANALYTICS_ID=your-analytics-id-here

# Cache Configuration
PRICE_CACHE_TTL=60
DASHBOARD_CACHE_TTL=15
MARKET_LIST_TTL=60
TOKEN_DETAIL_TTL=60
RUG_CACHE_TTL=300

# Security Configuration
MIN_LIQUIDITY_USD=10000
MIN_TOKEN_AGE_HOURS=24
MAX_OWNER_CONCENTRATION=0.5

# Solana RPC Configuration (used by backend)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Copy Trading Configuration
# Helius required for copy trading WebSocket monitoring
HELIUS_API_KEY=YOUR_HELIUS_API_KEY
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
# NEVER use example values in production. Store in secure vault (AWS Secrets Manager, HashiCorp Vault)
# Generate with: openssl rand -base64 32
WALLET_ENCRYPTION_KEY=YOUR_WALLET_ENCRYPTION_KEY
HEALTH_CHECK_PORT=3002

# Feature Flags
FEATURE_COPY_TRADING_ENABLED=true
FEATURE_SEND_ENABLED=true
FEATURE_SWAP_ENABLED=true
# MUST be false in production - Simulation mode bypasses actual blockchain transactions
FEATURE_SIMULATION_MODE=false

# JWT Configuration
# NEVER use example values in production. Store in secure vault (AWS Secrets Manager, HashiCorp Vault)
# Generate with: openssl rand -base64 32
JWT_SECRET=YOUR_JWT_SECRET
JWT_REFRESH_SECRET=YOUR_JWT_REFRESH_SECRET
# Balance security with user experience
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_EXP_SECONDS=900

# Admin Configuration
# NEVER use example values in production. Store in secure vault (AWS Secrets Manager, HashiCorp Vault)
# Generate with: openssl rand -base64 32
ADMIN_KEY=YOUR_ADMIN_KEY
ADMIN_API_KEY=YOUR_ADMIN_API_KEY
# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin@yourdomain.com

# Server Configuration
PORT=3001
NODE_ENV=production
HOST=0.0.0.0
LOG_LEVEL=info
# Restrict CORS to your actual domains only
ALLOWED_ORIGINS=https://app.soulwallet.com,https://www.soulwallet.com

# Email Provider Configuration
# Choose "smtp", "sendgrid", or "resend" (NOT "console")
EMAIL_PROVIDER=sendgrid
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=SoulWallet

# SMTP Configuration (if EMAIL_PROVIDER="smtp")
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SendGrid Configuration (if EMAIL_PROVIDER="sendgrid")
# Recommended for transactional emails
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY

# Resend Configuration (if EMAIL_PROVIDER="resend")
# Modern alternative to SendGrid
RESEND_API_KEY=YOUR_RESEND_API_KEY

# Authentication Security Settings
BCRYPT_ROUNDS=12
OTP_EXPIRES_IN_MINUTES=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
ACCOUNT_LOCKOUT_DURATION_MINUTES=30

# Session Configuration
SESSION_CLEANUP_INTERVAL_HOURS=24
SESSION_TIMEOUT_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=7
MAX_SESSIONS_PER_USER=5
# Strict fingerprinting prevents session hijacking
SESSION_FINGERPRINT_STRICT=true

# Security Features
ENABLE_SUSPICIOUS_LOGIN_ALERTS=true
ENABLE_ACCOUNT_LOCKOUT_NOTIFICATIONS=true
ENABLE_SESSION_ACTIVITY_LOGGING=true
ENABLE_GEOLOCATION_TRACKING=false

# Cleanup Service Configuration
CLEANUP_EXPIRED_SESSIONS_HOURS=24
CLEANUP_OLD_LOGIN_ATTEMPTS_DAYS=30
CLEANUP_SESSION_ACTIVITIES_DAYS=90
CLEANUP_EXPIRED_OTPS_HOURS=1
AUTO_UNLOCK_EXPIRED_ACCOUNTS=true

# Development Settings
# These expose internal API structure
ENABLE_PLAYGROUND=false
ENABLE_INTROSPECTION=false

# Additional Production Notes:
# - Store this file securely, never commit to version control
# - Use environment-specific files: .env.production, .env.staging
# - Consider using secret management services (AWS Secrets Manager, Vault)
# - Rotate secrets regularly (especially JWT secrets)
# - Use different database credentials for each environment
# - Enable database connection pooling for better performance
# - Set up automated backups for database
# - Configure log aggregation (CloudWatch, Datadog, Loggly)
# - Set up uptime monitoring (UptimeRobot, Pingdom)
# - Enable HTTPS/TLS for all connections
# - Use CDN for static assets if applicable